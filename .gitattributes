# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.db binary
