# Simulation Server Integration
SIM_SERVER_URL=http://localhost:3000

# Database Configuration
# SQLite for local development, PostgreSQL for production (Railway)
DATABASE_URL=sqlite:///data/sentinel4.db
# For Railway PostgreSQL: postgresql://user:password@hostname:5432/dbname

# History API Configuration
HISTORY_API_HOST=0.0.0.0
HISTORY_API_PORT=8010

# Groq LLM Configuration (for AI explanations)
GROQ_API_KEY=your_groq_api_key_here

# Twilio Configuration (optional, for voice alerts)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+your_phone_number

# Email Configuration (optional, for maintenance notifications)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECEIVER=supervisor@example.com

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8010
